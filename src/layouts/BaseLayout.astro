---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site.js';

const {
  title,
  description = site.description,
  canonical = site.url,
  ogImage = new URL(site.ogImage, site.url).href,
  ogImageAlt = site.ogImageAlt,
  robots = 'index, follow',
  basePath = '',
  showHeaderCta = true,
  showFooterCta = true,
  courseSchema = true,
  extraStylesheets = [],
  structuredData = []
} = Astro.props;

const assetPath = (path) => `${basePath}${path}`;
const siteUrl = (path = '') => new URL(path, site.url).href;
const organizationId = siteUrl('#organization');
const websiteId = siteUrl('#website');
const courseId = siteUrl('#course');
const organizationSchema = {
  '@type': 'Organization',
  '@id': organizationId,
  name: site.name,
  url: site.url,
  logo: siteUrl(site.logo),
  image: ogImage,
  description: site.description
};
const websiteSchema = {
  '@type': 'WebSite',
  '@id': websiteId,
  name: site.name,
  url: site.url,
  inLanguage: 'ru-RU',
  publisher: { '@id': organizationId }
};
const courseStructuredData = courseSchema ? {
  '@type': 'Course',
  '@id': courseId,
  name: 'Олимпиадная информатика для школьников 5-11 классов',
  description,
  inLanguage: 'ru-RU',
  provider: { '@id': organizationId },
  isPartOf: { '@id': websiteId },
  educationalLevel: '5-11 классы',
  teaches: [
    'олимпиадная информатика',
    'алгоритмы и структуры данных',
    'программирование на C++, Python и Java',
    'математика для информатики'
  ],
  audience: {
    '@type': 'EducationalAudience',
    educationalRole: 'student',
    audienceType: 'школьники 5-11 классов'
  },
  offers: {
    '@type': 'Offer',
    url: canonical,
    price: '3000',
    priceCurrency: 'RUB',
    availability: 'https://schema.org/InStock',
    category: 'онлайн-занятия'
  }
} : null;
const schemaGraph = [
  organizationSchema,
  websiteSchema,
  courseStructuredData,
  ...structuredData
].filter(Boolean);
const structuredDataPayload = {
  '@context': 'https://schema.org',
  '@graph': schemaGraph
};
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#FFFFFF" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={assetPath('assets/favicon.svg')} type="image/svg+xml" />
    <link rel="stylesheet" href={assetPath(`assets/styles.css?v=${site.stylesheetVersion}`)} />{extraStylesheets.map((href) => <link rel="stylesheet" href={assetPath(href)} />)}
    <script defer src={assetPath(`assets/main.js?v=${site.scriptVersion}`)}></script>
    <!-- Yandex.Metrika counter -->
    <script type="text/javascript" is:inline>
      (function(m,e,t,r,i,k,a){
        m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
        m[i].l=1*new Date();
        for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
        k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
      })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=109571501', 'ym');

      ym(109571501, 'init', {ssr:true, webvisor:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true});
    </script>
    <!-- /Yandex.Metrika counter -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredDataPayload)}></script>
    <title>{title}</title>
  </head>
  <body>
    <noscript><div><img src="https://mc.yandex.ru/watch/109571501" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    <a class="skip-link" href="#main">К основному содержанию</a>
    <Header basePath={basePath} showCta={showHeaderCta} />
    <main id="main">
      <slot />
    </main>
    <Footer basePath={basePath} showCta={showFooterCta} />
  </body>
</html>
