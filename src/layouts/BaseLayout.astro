---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site.js';

const {
  title,
  description = site.description,
  canonical = site.url,
  ogImage = `${site.url}assets/og-image.png`,
  basePath = '',
  courseSchema = true
} = Astro.props;

const assetPath = (path) => `${basePath}${path}`;
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FFFFFF" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={assetPath('assets/favicon.svg')} type="image/svg+xml" />
    <link rel="stylesheet" href={assetPath(`assets/styles.css?v=${site.stylesheetVersion}`)} />
    <script defer src={assetPath(`assets/main.js?v=${site.scriptVersion}`)}></script>
    <!-- Yandex.Metrika counter -->
    <script type="text/javascript" is:inline>
      (function(m,e,t,r,i,k,a){
        m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
        m[i].l=1*new Date();
        for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
        k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
      })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=109571501', 'ym');

      ym(109571501, 'init', {ssr:true, webvisor:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true});
    </script>
    <!-- /Yandex.Metrika counter -->
    {courseSchema && <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Course',
      name: 'Олимпиадная информатика онлайн для школьников 5-11 классов',
      description: 'Онлайн-занятия по олимпиадной информатике для школьников 5-11 классов.',
      provider: {
        '@type': 'Organization',
        name: site.name,
        url: site.url
      },
      offers: {
        '@type': 'Offer',
        price: '3000',
        priceCurrency: 'RUB',
        availability: 'https://schema.org/InStock'
      }
    })}></script>}
    <title>{title}</title>
  </head>
  <body>
    <noscript><div><img src="https://mc.yandex.ru/watch/109571501" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    <a class="skip-link" href="#main">К основному содержанию</a>
    <Header basePath={basePath} />
    <main id="main">
      <slot />
    </main>
    <Footer basePath={basePath} />
  </body>
</html>
