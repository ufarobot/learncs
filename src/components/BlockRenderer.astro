---
import HeroSplitBlock from './blocks/HeroSplitBlock.astro';
import SplitMediaBlock from './blocks/SplitMediaBlock.astro';
import CardGridBlock from './blocks/CardGridBlock.astro';
import MediaStackBlock from './blocks/MediaStackBlock.astro';
import ImageShowcaseBlock from './blocks/ImageShowcaseBlock.astro';
import TwoColumnListBlock from './blocks/TwoColumnListBlock.astro';
import CenteredSummaryBlock from './blocks/CenteredSummaryBlock.astro';
import LogoGridBlock from './blocks/LogoGridBlock.astro';
import FaqAccordionBlock from './blocks/FaqAccordionBlock.astro';
import CurriculumAccordionBlock from './blocks/CurriculumAccordionBlock.astro';
import CtaPanelBlock from './blocks/CtaPanelBlock.astro';

const { block } = Astro.props;

const templates = {
  'hero-split': HeroSplitBlock,
  'split-media': SplitMediaBlock,
  'card-grid': CardGridBlock,
  'media-stack': MediaStackBlock,
  'image-showcase': ImageShowcaseBlock,
  'two-column-list': TwoColumnListBlock,
  'centered-summary': CenteredSummaryBlock,
  'logo-grid': LogoGridBlock,
  'faq-accordion': FaqAccordionBlock,
  'curriculum-accordion': CurriculumAccordionBlock,
  'cta-panel': CtaPanelBlock,
};

const Component = templates[block.template];

if (!Component) {
  throw new Error(`Unknown landing block template: ${block.template}`);
}
---
<Component block={block} />
