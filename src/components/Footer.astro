---
import { footerCta, footerLinks, site } from '../data/site.js';

const { basePath = '' } = Astro.props;
const rootHref = basePath || './';
const localHref = (href) => {
  if (href.startsWith('http') || href.startsWith('#')) {
    if (href.startsWith('#')) {
      return `${rootHref}${href}`;
    }
    return href;
  }
  if (href === './') {
    return rootHref;
  }
  return `${basePath}${href}`;
};
const linkAttributes = (item) => ({
  target: item.target,
  rel: item.rel || (item.target === '_blank' ? 'noopener noreferrer' : undefined)
});
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <a class="brand footer-brand" href={rootHref} aria-label={site.name}>
        <img class="brand-mark" src={`${basePath}assets/logo-icon-white-on-black.png?v=2`} alt="" />
        <span class="brand-text">{site.name}</span>
      </a>
      <p>{site.description}</p>
    </div>
    <div class="footer-actions">
      {footerCta && (
        <div class="footer-cta">
          <p class="footer-cta-title">{footerCta.title}</p>
          <a class="button button-primary footer-cta-button" href={localHref(footerCta.href)} {...linkAttributes(footerCta)}>{footerCta.label}</a>
        </div>
      )}
      {footerLinks.length > 0 && (
        <nav class="footer-links" aria-label="Ссылки">
          {footerLinks.map((item) => <a href={localHref(item.href)} {...linkAttributes(item)}>{item.label}</a>)}
        </nav>
      )}
    </div>
  </div>
</footer>
