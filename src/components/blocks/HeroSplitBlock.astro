---
const { block } = Astro.props;

const buttonClasses = {
  primary: 'button-primary',
  secondary: 'button-secondary',
  quiet: 'button-quiet',
  accent: 'button-accent',
};

const actionAttributes = (action) => ({
  target: action.target,
  rel: action.rel || (action.target === '_blank' ? 'noopener noreferrer' : undefined),
});

const normalizeFact = (fact) => {
  if (Array.isArray(fact)) {
    return { title: fact[0], text: fact[1] };
  }

  return fact;
};
---
<section class="hero" id={block.id} data-template={block.template}>
  <div class="container hero-shell">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="pretitle">{block.pretitle}</p>
        <h1>{block.title}</h1>
        <p class="lead">{block.lead}</p>
        {block.languages && <p class="hero-languages">{block.languages}</p>}
        <div class="button-row">
          {block.actions.map((action) => (
            <a class:list={['button', buttonClasses[action.style || 'quiet']]} href={action.href} {...actionAttributes(action)}>{action.label}</a>
          ))}
        </div>
      </div>

      <div class="hero-media">
        <div class="hero-media-card">
          <figure class="hero-visual">
            <img src={block.media.src} alt={block.media.alt} loading="eager" fetchpriority="high" decoding="async" />
          </figure>
        </div>
      </div>

      <div class="hero-facts hero-facts-card" aria-label="Факты о курсе">
        {block.facts.map((fact) => {
          const item = normalizeFact(fact);

          return (
          <article class="hero-fact">
            <p class="fact-title">{item.title}</p>
            {item.text
              .split(/\n\s*\n/)
              .map((paragraph) => paragraph.trim())
              .filter(Boolean)
              .map((paragraph) => <p>{paragraph}</p>)}
            {item.emphasis && <p class="text-accent-practical">{item.emphasis}</p>}
          </article>
          );
        })}
      </div>
    </div>
  </div>
</section>
