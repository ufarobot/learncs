---
const { block } = Astro.props;
const sectionClass = ['section', block.surface === 'muted' && 'section-muted'];
const buttonClasses = {
  primary: 'button-primary',
  secondary: 'button-secondary',
  quiet: 'button-quiet',
};
---
<section class:list={sectionClass} id={block.id} data-template={block.template} data-spacing={block.spacing}>
  <div class="container cta-panel">
    <div>
      <h2>{block.title}</h2>
      {block.text && <p>{block.text}</p>}
    </div>
    <a class:list={['button', buttonClasses[block.action.style || 'primary']]} href={block.action.href}>{block.action.label}</a>
  </div>
</section>
