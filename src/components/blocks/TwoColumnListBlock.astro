---
const { block } = Astro.props;
const sectionClass = ['section', block.surface === 'muted' && 'section-muted'];
---
<section class:list={sectionClass} id={block.id} data-template={block.template}>
  <div class="container two-column-list-layout">
    {block.columns.map((column) => (
      <div class:list={['list-panel', column.tone === 'muted' && 'list-panel-muted']}>
        <h2>{column.title}</h2>
        <ul class="plain-list">
          {column.items.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    ))}
  </div>
</section>
