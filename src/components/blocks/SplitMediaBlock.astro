---
const { block } = Astro.props;
const sectionClass = ['section', block.surface === 'muted' && 'section-muted'];
const headingPlacement = block.headingPlacement || 'side';
const mediaPlacement = block.mediaPlacement || 'left';
---
<section class:list={sectionClass} id={block.id} data-template={block.template} data-spacing={block.spacing}>
  {headingPlacement === 'top' && (
    <div class="container split-media-head">
      <h2>{block.title}</h2>
      {block.lead && <p>{block.lead}</p>}
    </div>
  )}

  <div class="container split-media-layout" data-media-placement={mediaPlacement} data-media-align={block.mediaAlign}>
    <figure class="split-media-visual">
      <img src={block.media.src} alt={block.media.alt} loading="lazy" decoding="async" />
      {block.mediaTitle && <figcaption>{block.mediaTitle}</figcaption>}
      {block.mediaText && <p>{block.mediaText}</p>}
    </figure>

    <div class:list={['split-media-copy', headingPlacement === 'top' && 'split-media-copy-topless']}>
      {headingPlacement === 'side' && (
        <>
          <h2>{block.title}</h2>
          {block.lead && <p class="split-media-lead">{block.lead}</p>}
        </>
      )}

      {block.cards && (
        <div class="split-media-detail" aria-label={block.detailLabel || block.title}>
          {block.detailLabel && <p class="split-media-detail-title">{block.detailLabel}</p>}

          <div
            class="split-media-detail-grid"
            data-columns={block.detailColumns || 2}
            data-card-tone={block.detailCardTone}
            data-detail-style={block.detailStyle}
          >
            {block.cards.map((card) => (
              <article class:list={[card.wide && 'split-media-detail-wide', !card.title && 'split-media-detail-text-only']}>
                {card.title && <h3>{card.title}</h3>}
                {card.text && <p>{card.text}</p>}
                {card.items && (
                  <ul class="plain-list">
                    {card.items.map((item) => <li>{item}</li>)}
                  </ul>
                )}
              </article>
            ))}
          </div>
        </div>
      )}

      {block.notes && (
        <div class="split-media-notes">
          {block.notes.map((note) => <p>{note}</p>)}
        </div>
      )}

      {block.proof && <p class="split-media-proof">{block.proof}</p>}
    </div>
  </div>
</section>
