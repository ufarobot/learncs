---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../data/site.js';
import { getCollection, render } from 'astro:content';
import { canonicalMaterialSlug, isDuplicateMaterialSlug, isHiddenMaterialSlug } from '../../lib/material-duplicates.js';

export async function getStaticPaths() {
  const entries = await getCollection('materials');

  return entries
    .filter((entry) => !isHiddenMaterialSlug(entry.id))
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const isDuplicate = isDuplicateMaterialSlug(entry.id);
const canonicalSlug = canonicalMaterialSlug(entry.id);
const redirectPath = `/materials/${canonicalSlug}/`;
const redirectUrl = new URL(redirectPath, site.url).href;
const { Content } = await render(entry);
const material = entry.data;
const rawBody = entry.body?.trimStart() ?? '';
const shouldRenderRawHtml = rawBody.startsWith('<');
const canonical = isDuplicate ? redirectUrl : new URL(`materials/${entry.id}/`, site.url).href;
const articleStructuredData = {
  '@type': 'Article',
  '@id': canonical,
  headline: material.title,
  description: material.description,
  inLanguage: 'ru-RU',
  datePublished: material.publishedAt,
  mainEntityOfPage: canonical,
  isPartOf: { '@id': new URL('#website', site.url).href },
  author: {
    '@type': 'Person',
    name: 'Айрат Ишимбаев',
  },
  publisher: { '@id': new URL('#organization', site.url).href },
};
---
{isDuplicate ? (
  <html lang="ru">
    <head>
      <meta charset="utf-8" />
      <meta name="robots" content="noindex" />
      <meta http-equiv="refresh" content={`0; url=${redirectPath}`} />
      <link rel="canonical" href={redirectUrl} />
      <title>{material.title} — learncs.ru</title>
    </head>
    <body>
      <p><a href={redirectPath}>Открыть статью</a></p>
    </body>
  </html>
) : (
  <BaseLayout
    title={`${material.title} — learncs.ru`}
    description={material.description}
    canonical={canonical}
    basePath="../../"
    courseSchema={false}
    showHeaderCta={false}
    showFooterCta={false}
    extraStylesheets={['assets/styles.css?v=20260612-navigator-clean-v3']}
    structuredData={[articleStructuredData]}
  >
    <article class="article-page">
      <header class="container article-hero">
        <a class="article-back-link" href="../../navigator/">Навигатор</a>
        <h1>{material.title}</h1>
      </header>

      <div class="container article-layout article-layout-single">
        <div class="article-prose">
          {shouldRenderRawHtml ? <Fragment set:html={entry.body} /> : <Content />}
        </div>
      </div>
    </article>
  </BaseLayout>
)}
