---
import { navigatorStaticPaths, readNavigatorHtml } from '../../lib/navigator-static.js';

export async function getStaticPaths() {
  return navigatorStaticPaths();
}

Astro.response.headers.set('content-type', 'text/html; charset=utf-8');

const html = await readNavigatorHtml(Astro.params.path);
---

<Fragment set:html={html} />
